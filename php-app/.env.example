DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=moodswings
DB_USER=root
DB_PASSWORD=

# Public base URL the app is served at (no trailing slash), used to build
# links in emails, e.g. https://example.com/app if deployed under /app.
APP_URL=http://localhost:8000

# SMTP credentials used to send the email verification link at registration.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=MoodSwings
