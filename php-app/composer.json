{
    "name": "moodswings/php-app",
    "description": "PHP application for the MoodSwings-Web simulator",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MoodSwings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MoodSwings\\Tests\\": "tests/"
        }
    }
}
